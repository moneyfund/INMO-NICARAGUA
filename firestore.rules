rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/agents/$(request.auth.uid))
        && get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'admin';
    }

    match /agents/{agentId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == agentId;
      allow delete: if false;
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.resource.data.agentId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
          (resource.data.agentId == request.auth.uid && request.resource.data.agentId == request.auth.uid)
          || isAdmin()
        );
      allow delete: if isSignedIn() && (resource.data.agentId == request.auth.uid || isAdmin());
    }

    match /properties/{propertyId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
    }


    match /sharedPropertyLists/{listId} {
      allow read: if resource.data.status == 'active'
        || (isSignedIn() && resource.data.createdByAgentId == request.auth.uid)
        || isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.createdByAgentId == request.auth.uid
        && request.resource.data.token is string
        && request.resource.data.token.size() >= 12
        && request.resource.data.propertyIds is list
        && request.resource.data.status in ['active', 'inactive'];

      allow update: if isSignedIn() && (
          (resource.data.createdByAgentId == request.auth.uid
            && request.resource.data.createdByAgentId == resource.data.createdByAgentId
            && request.resource.data.token == resource.data.token)
          || isAdmin()
        );

      allow delete: if isSignedIn() && (resource.data.createdByAgentId == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
